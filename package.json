{
  "name": "cody-special",
  "version": "0.1.0",
  "description": "Cody special functions and normal distribution utilities for TypeScript.",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./erfCody": {
      "types": "./dist/src/erfCody.d.ts",
      "import": "./dist/src/erfCody.js"
    },
    "./normalDistribution": {
      "types": "./dist/src/normalDistribution.d.ts",
      "import": "./dist/src/normalDistribution.js"
    }
  },
  "files": [
    "dist/src"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/vollib/cody-special-ts.git"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.test.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "typescript": "^5.4.5",
    "vollib-test-vectors": "git+ssh://git@github.com/vollib/vollib-test-vectors.git#c5fb306508779646bf70edb57f26ccf4fbaa540f"
  },
  "license": "MIT"
}
